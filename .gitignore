# =========================
# Cameroon Land Registry — root
# =========================

# Dependencies
node_modules/
**/node_modules/
.pnp
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Environment & secrets (keep examples)
.env
.env.*
!.env.example
!backend/.env.example
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build outputs
dist/
build/
out/
.next/
.nuxt/
.output/
.vite/
*.tsbuildinfo

# Testing & coverage
coverage/
.nyc_output/
*.lcov

# Caches
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache
*.swp
*.swo
*~

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# IDEs & editors
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# Deployment / hosting
.vercel/
.netlify/
.firebase/

# v0 / sandbox artifacts (legacy)
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts
.snowflake/
.v0-trash/

# Database dumps & local data
*.sql.gz
*.dump
pgdata/
postgres-data/

# Uploaded user files (tracked structure only via .gitkeep)
backend/uploads/*
!backend/uploads/.gitkeep

# Temporary files
tmp/
temp/
*.tmp
*.temp
*.bak

# Optional local tooling
.cursor/
*.local.md
